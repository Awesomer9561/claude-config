        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/parvezali/.claude/hooks/code-review-gate.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/parvezali/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/parvezali/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"/Users/parvezali/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
